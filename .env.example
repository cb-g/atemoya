# Atemoya Environment Configuration
# Copy this file to .env and fill in your values
# The .env file is gitignored and will not be committed
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   source .env  # Load into current shell
#   ./quickstart.sh

# ============================================================================
# Interactive Brokers (IBKR) - Optional
# ============================================================================
# Only needed if using IBKR as data provider instead of yfinance
# Leave empty to use yfinance (default, no account needed)

# Mode: "tws" for Trader Workstation, "gateway" for IB Gateway/Client Portal
IBKR_MODE=tws

# TWS/Gateway connection settings
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# For Gateway mode only
IBKR_GATEWAY_URL=https://localhost:5000/v1/api
IBKR_ACCOUNT_ID=

# ============================================================================
# Watchlist Notifications (ntfy.sh) - Optional
# ============================================================================
# Only needed if using watchlist alert notifications
# ntfy.sh is a free, open-source push notification service

# Your ntfy topic name (you choose this, like a channel name)
NTFY_TOPIC=

# ntfy server URL (default is the public server)
NTFY_SERVER=https://ntfy.sh

# ============================================================================
# Data Provider Selection - Optional
# ============================================================================
# Which data provider to use: "yfinance" (default, free) or "ibkr" (requires account)
DATA_PROVIDER=yfinance

# ============================================================================
# FRED API Key - Optional
# ============================================================================
# Free API key for Federal Reserve Economic Data (FRED)
# Used by: Macro Dashboard (monitoring/macro_dashboard)
# Get your free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ============================================================================
# SEC EDGAR Identity - Optional
# ============================================================================
# SEC EDGAR requires a User-Agent string identifying your tool and contact.
# No registration needed — this is an honor-system identification.
# Format: "Company/Tool Name email@example.com"
SEC_EDGAR_IDENTITY="YourName your@email.com"

# ============================================================================
# ThetaData - Optional
# ============================================================================
# Secondary options data source with 1-year historical backfill.
# Free account at: https://www.thetadata.net
# Requires Theta Terminal JAR + Java 21 running locally.
THETADATA_EMAIL=
THETADATA_PASSWORD=

